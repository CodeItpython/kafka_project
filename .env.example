# Copy this file to .env and fill real local secrets.
# Do not commit .env.

KAKAO_CLIENT_ID=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_REDIRECT_URI=http://localhost:8890/oauth2/callback/kakao

# 네이버 아이디로 로그인(로그인 전용 앱 자격증명; 검색 API의 NAVER_CLIENT_* 와 별개).
NAVER_LOGIN_CLIENT_ID=your_naver_login_client_id
NAVER_LOGIN_CLIENT_SECRET=your_naver_login_client_secret
NAVER_LOGIN_REDIRECT_URI=http://localhost:8890/oauth2/callback/naver

JWT_SECRET=replace-with-at-least-32-bytes-local-secret

OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-5.2
OPENAI_RESPONSES_URL=https://api.openai.com/v1/responses

# Docker/Kubernetes object storage. Local IDE bootRun uses APP_STORAGE_TYPE=local by default.
APP_STORAGE_TYPE=s3
APP_STORAGE_S3_ENDPOINT=http://localhost:9000
APP_STORAGE_S3_REGION=us-east-1
APP_STORAGE_S3_BUCKET=kafka-talk-files
APP_STORAGE_S3_ACCESS_KEY=kafka-talk
APP_STORAGE_S3_SECRET_KEY=kafka-talk-secret
APP_STORAGE_S3_PATH_STYLE_ACCESS=true

# Observability. Docker/Kubernetes sets these automatically for auth-service.
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0
MANAGEMENT_OTLP_TRACING_ENDPOINT=http://localhost:4318/v1/traces

# 네이버 검색 API 자격증명(로그인용 NAVER_LOGIN_* 와 별개). 실제 값은 .env 에만 둘 것.
NAVER_CLIENT_ID=your_naver_search_client_id
NAVER_CLIENT_SECRET=your_naver_search_client_secret

# 온통청년 청년정책 Open API 키(청년 정책·혜택 탭). youthcenter.go.kr 가입 → 마이페이지 OPEN API 신청.
# data.go.kr가 인코딩/디코딩 두 키를 주면 "디코딩(Decoding)" 키를 넣을 것. 미설정 시 정책 탭만 비어있음.
YOUTH_API_KEY=your_youthcenter_decoding_api_key
